# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (PostgreSQL with Prisma)
# Replace user, password, host, port, and dbname with your credentials
DATABASE_URL="postgresql://postgres:password@localhost:5432/share_bill?schema=public"

# Authentication
JWT_SECRET="your_jwt_secret_key_here"
JWT_EXPIRES_IN="7d"

# CORS
CORS_ORIGIN="http://localhost:5173"
