# ==============================================================================
# SHARE BILL - PRODUCTION BACKEND CONFIGURATION TEMPLATE
# Save a copy of this file as .env in your production environment.
# ==============================================================================

# Server Configuration
# The port that the web server will bind to. (Render/Railway set this automatically)
PORT=5000
NODE_ENV=production

# Database Configuration (PostgreSQL with Prisma)
# Replace user, password, host, port, and dbname with your production database credentials.
# Make sure to append "?schema=public" if you are using PostgreSQL schemas.
DATABASE_URL="postgresql://db_user:db_password@db_host:5432/db_name?schema=public"

# Authentication Config
# WARNING: Change this value to a strong, random, and secret string in production.
# Do not share this key or commit it to version control.
JWT_SECRET="generate_a_secure_random_string_here"
JWT_EXPIRES_IN="7d"

# Cross-Origin Resource Sharing (CORS) Configuration
# Set this to your production frontend URLs (e.g., Vercel host).
# To allow multiple origins, separate them by commas: "https://app.com,https://preview.app.com"
# To allow all Vercel deployment previews securely, you can use: "*.vercel.app"
CORS_ORIGIN="https://your-frontend-app.vercel.app"
